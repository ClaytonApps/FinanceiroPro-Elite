rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Cada usuário acessa apenas o próprio documento
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Subcoleções do usuário (futuro: histórico, anexos grandes, etc.)
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
